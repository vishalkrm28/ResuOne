# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/parsepilot

# ─── Replit Auth (auto-injected by Replit, do not set manually) ───────────────
REPL_ID=
ISSUER_URL=https://replit.com/oidc

# ─── AI / OpenAI ───────────────────────────────────────────────────────────────
# Injected automatically when the OpenAI integration is connected in Replit.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Stripe Billing ────────────────────────────────────────────────────────────
# Secret key from your Stripe dashboard (use sk_test_... for development)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from `stripe listen --forward-to localhost:8080/api/stripe/webhook`
# (dev) or Dashboard → Webhooks → Signing secret (production)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Price IDs ──────────────────────────────────────────────────────────
# Pro subscription — $14.99/month
STRIPE_PRICE_PARSEPILOT_PRO=price_...

# One-time single CV unlock — $6.99
STRIPE_PRICE_PARSEPILOT_SINGLE_UNLOCK=price_...

# Bulk CV packs (one-time payments)
STRIPE_PRICE_PARSEPILOT_BULK_10=price_...   # $19 — 10 CVs
STRIPE_PRICE_PARSEPILOT_BULK_25=price_...   # $29 — 25 CVs
STRIPE_PRICE_PARSEPILOT_BULK_50=price_...   # $39 — 50 CVs

# ─── App URLs ──────────────────────────────────────────────────────────────────
# URL Stripe returns the user to after managing their subscription
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://your-app.replit.app/settings
