# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/parsepilot

# ─── Replit Auth (auto-injected by Replit, do not set manually) ───────────────
REPL_ID=
ISSUER_URL=https://replit.com/oidc

# ─── OpenAI / Responses API ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe Billing ────────────────────────────────────────────────────────────
# Secret key from your Stripe dashboard (use sk_test_... for development)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from `stripe listen` (dev) or Dashboard → Webhooks (prod)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID of the ParsePilot Pro Monthly plan in your Stripe dashboard
STRIPE_PRICE_PARSEPILOT_PRO=price_...

# ─── App URLs ──────────────────────────────────────────────────────────────────
# Full public URL of the app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://your-app.replit.app

# URL Stripe returns the user to after managing their subscription
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://your-app.replit.app/dashboard
