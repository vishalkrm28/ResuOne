modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
STRIPE_PRICE_PARSEPILOT_PRO = "price_1TFYEYJTOaZlsJyqZJfEStUt"
STRIPE_PRICE_PARSEPILOT_SINGLE_UNLOCK = "price_1TFYCvJTOaZlsJyqcoPjFasU"
STRIPE_PRICE_PARSEPILOT_BULK_10 = "price_1TFYKLJTOaZlsJyqRnyLE5FM"
STRIPE_PRICE_PARSEPILOT_BULK_25 = "price_1TFYKLJTOaZlsJyq2PIy5dlA"
STRIPE_PRICE_PARSEPILOT_BULK_50 = "price_1TFYKLJTOaZlsJyq7bsdB2Vq"
